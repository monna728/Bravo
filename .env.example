# Copy to ".env" in the repo root (never commit .env).
# Ticketmaster Discovery API — https://developer.ticketmaster.com/
TICKETMASTER_API_KEY=

# NYC Open Data Socrata (optional, higher rate limits) — https://data.cityofnewyork.us/profile/edit/developer_settings
NYC_OPENDATA_APP_TOKEN=
# Optional: TLC page size / HTTP tuning (defaults: 2000 rows/page, 20s connect, 300s read, 3 retries)
# NYC_TLC_PAGE_LIMIT=
# NYC_TLC_CONNECT_TIMEOUT=
# NYC_TLC_READ_TIMEOUT=
# NYC_TLC_HTTP_RETRIES=
